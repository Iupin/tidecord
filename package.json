{
  "name": "tidecord",
  "version": "1.0.1",
  "description": "",
  "main": "dist/index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "tsc",
    "dist": "npm run build && electron-builder"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Iupin/tidecord.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Iupin/tidecord/issues"
  },
  "homepage": "https://github.com/Iupin/tidecord#readme",
  "dependencies": {
    "@xhayper/discord-rpc": "^1.3.1"
  },
  "build": {
    "appId": "com.tidecord.app",
    "win": {
      "target": "nsis"
    },
    "files": [
      "dist/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "icon.ico",
        "to": "icon.ico"
      },
      {
        "from": "bridge",
        "to": "bridge"
      }
    ]
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
